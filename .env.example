# =============================================================================
#  Ripple Innovation Labs — backend environment template
#  Copy to `.env` and fill in. DJANGO_ENV selects the settings module:
#    development -> ripple/settings/dev.py   (SQLite, console email, DEBUG on)
#    production  -> ripple/settings/prod.py  (DATABASE_URL, SMTP, HTTPS, DEBUG off)
# =============================================================================

DJANGO_ENV=development

# -----------------------------------------------------------------------------
#  Paystack (get TEST keys from https://dashboard.paystack.com/#/settings/developers)
# -----------------------------------------------------------------------------
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Charge currency: NGN or USD (USD requires a USD-enabled Paystack account)
PAYSTACK_CURRENCY=NGN
# Used only when PAYSTACK_CURRENCY=NGN, to convert USD quotes into Naira
USD_TO_NGN_RATE=1600
# Paystack transaction fee shown on the invoice (percentage)
PAYSTACK_FEE_PERCENT=1.5

# =============================================================================
#  PRODUCTION — set DJANGO_ENV=production and fill everything below.
#  (In development none of these are needed — dev.py supplies safe defaults.)
# =============================================================================

# A long random string:  python -c "import secrets; print(secrets.token_urlsafe(64))"
# SECRET_KEY=change-me

# Django host(s) that serve the API — include both the bare domain and www if needed
# ALLOWED_HOSTS=api.ripplenovate.com,www.api.ripplenovate.com

# Database — MySQL (typical cPanel) or PostgreSQL
# DATABASE_URL=mysql://cpuser_dbuser:URL_ENCODED_PASSWORD@localhost:3306/cpuser_dbname
# DATABASE_URL=postgres://user:pass@localhost:5432/dbname

# The domain that serves the React app + CORS / CSRF
# FRONTEND_URL=https://www.ripplenovate.com
# CORS_ALLOWED_ORIGINS=https://www.ripplenovate.com,https://ripplenovate.com
# CSRF_TRUSTED_ORIGINS=https://api.ripplenovate.com,https://www.ripplenovate.com,https://ripplenovate.com
# SECURE_SSL_REDIRECT=True

# SMTP email
# DEFAULT_FROM_EMAIL=Ripple Innovation Labs <no-reply@ripplenovate.com>
# EMAIL_HOST=mail.ripplenovate.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=no-reply@ripplenovate.com
# EMAIL_HOST_PASSWORD=your-mailbox-password
# EMAIL_USE_TLS=True

# Use Paystack LIVE keys in production:
# PAYSTACK_SECRET_KEY=sk_live_xxxxxxxx
# PAYSTACK_PUBLIC_KEY=pk_live_xxxxxxxx
