# ---- Django ----
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ---- Database ----
# Local dev uses SQLite by default — no database server required.
USE_SQLITE=True
# For PostgreSQL: set USE_SQLITE=False and uncomment the line below.
# DATABASE_URL=postgres://localhost:5432/ripple_labs

# ---- CORS / frontend ----
FRONTEND_URL=http://localhost:5180
CORS_ALLOWED_ORIGINS=http://localhost:5180

# ---- Email (dev prints to console; set SMTP for production) ----
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=Ripple Innovation Labs <no-reply@rippleinnovationlabs.test>
# For production SMTP, switch EMAIL_BACKEND to smtp and set:
# EMAIL_HOST=
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=True

# ---- Paystack (get TEST keys from https://dashboard.paystack.com/#/settings/developers) ----
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Charge currency: NGN or USD (USD requires a USD-enabled Paystack account)
PAYSTACK_CURRENCY=NGN
# Used only when PAYSTACK_CURRENCY=NGN, to convert USD quotes into Naira
USD_TO_NGN_RATE=1600
# Paystack transaction fee shown on the invoice (percentage)
PAYSTACK_FEE_PERCENT=1.5
